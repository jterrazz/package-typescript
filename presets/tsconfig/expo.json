{
    "display": "Expo",
    "include": ["../../../../**/*.ts", "../../../../**/*.tsx"],
    "exclude": ["../../../../node_modules"],

    "compilerOptions": {
        "allowJs": true,
        "baseUrl": ".",
        "esModuleInterop": true,
        "jsx": "react-native",
        "lib": ["DOM", "ESNext"],
        "moduleResolution": "node",
        "noEmit": true,
        "paths": {
            "@/*": ["src/*"]
        },
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "target": "ESNext"
    }
}
